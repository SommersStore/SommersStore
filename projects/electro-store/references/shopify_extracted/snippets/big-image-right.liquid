{% if _tab_style == '1' %}
  {%- assign _class = 'col-lg-3 col-md-6 col-sm-6' -%}
{% else %}
  {%- assign _class = 'col-lg-4 col-md-6 col-sm-12' -%}
{% endif %}

<div class="wrap-grid-item">
  <div class="row">

    {% unless block.settings.collection == blank or collection.products_count == 0 %}
      {% for product in collection.products limit: _limit %}
        <div class="{{ _class }} col-12">
          {% include 'product-item' %}
        </div>	
      {% endfor %}

    {% else %}
      {{ emptyProduct05 }}
    {% endunless %}

  </div>
</div>

<div class="big-grid-item">
  <div class="big-image-item">
    
    <a href="{{ collection.url }}"><img src="{{ _big_image | img_url: _big_image_size }}'" alt="Banner" /></a>

  </div>
</div>