{% if section.blocks.size > 0 %}
  {% assign _layout = section.settings.layout %}
  {% assign _lazyload = section.settings.lazyload %}

  <div id="bottom-widget">
    <div class="bottom-container layout-{{ _layout }}">
      {% if _layout == 'boxed' %}<div class="container">{% endif %}

        {% if section.settings.logo_list %}
          <div class="bottom-partner">
            <div class="bottom-partner-list">

              {% for block in section.blocks %}
                {% if block.type == 'logo-list' %}

                  <div class="partner-item">
                    {% unless block.settings.image == blank %}
                      <a href="{{ block.settings.link }}"{% if _lazyload %} class="lazyload waiting"{% endif %}>
                        <img {% if _lazyload %}class="lazyload" data-{% endif %}src="{{ block.settings.image | img_url: '270x' }}" alt="Partner" />
                      </a>

                    {% else %}
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}

                    {% endunless %}
                  </div>

                {% endif %}
              {% endfor %}

            </div>
          </div>
        {% endif %}

        {% if section.settings.products_listing %}
          <div class="bottom-products">   
            <div class="product-listing-items">
              <div class="row"> 

                {% for block in section.blocks %}
                  {% if block.type == 'products-listing' %}

                    {%- assign collection = collections[block.settings.collection] -%}
                    {%- assign _title = block.settings.title -%}

                    <div class="col-lg-4 col-md-4 col-sm-12">
                      <div class="listing-items-col">

                        {% unless block.settings.collection == blank or collection.products_count == 0 %}
                          <h4>{% unless _title == blank %}{{ _title }}{% else %}{{ collection.title }}{% endunless %}</h4>

                          {% for product in collection.products limit: 3 %}
                            {% include 'products-listing-item' %}
                          {% endfor %}

                        {% else %}
                          <h4>{% unless _title == blank %}{{ _title }}{% else %}{{ 'homepage.onboarding.products_listing_title' | t }}{% endunless %}</h4>
                          {{ emptyProduct }}

                        {% endunless%}

                      </div>
                    </div>

                  {% endif %}
                {% endfor %}

              </div>
            </div>
          </div>
        {% endif %}

      {% if _layout == 'boxed' %}</div>{% endif %}
    </div>
  </div>
{% endif %}


{% schema %}
  {
    "name": "Bottom",
    "settings": [
      {
        "type": "select",
        "id": "layout",
        "label": "Section Layout Mode",
        "default": "boxed",
        "options": [
          {
            "value": "boxed",
            "label": "Boxed"
          },
          {
            "value": "full",
            "label": "Wide"
          }
        ]
      },
      {
        "type": "checkbox",
        "id": "lazyload",
        "label": "Enable Lazy loading",
        "default": true
      },
      {
        "type": "header",
        "content": "Logo List"
      },
      {
        "type": "checkbox",
        "id": "logo_list",
        "label": "Show logo list",
        "default": true
      },
      {
        "type": "header",
        "content": "Product Listing"
      },
      {
        "type": "checkbox",
        "id": "products_listing",
        "label": "Show product listing",
        "default": true
      }
    ],
    "blocks": [
      {
        "type": "logo-list",
        "name": "Logo List",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image",
			"info": "The default image size is 270x70 pixels"
          },
          {
            "type": "url",
            "id": "link",
            "label": "Link to"
          }
        ]
      },
      {
        "type": "products-listing",
        "name": "Products Listing",
        "settings": [
          {
            "type": "text",
            "id": "title",
            "label": "Heading",
            "default": "Featured products"
          },
          {
            "id": "collection",
            "type": "collection",
            "label": "Collection"
          }
        ]
      }
    ],
	"presets": [
      {
        "name": "Bottom - Static Section",
        "blocks": [
          { "type": "logo-list" },
          { "type": "logo-list" },
          { "type": "logo-list" },
          { "type": "logo-list" },
          { "type": "logo-list" },
          { "type": "logo-list" },
          { "type": "logo-list" },
          { "type": "logo-list" },
          { "type": "products-listing" },
          { "type": "products-listing" },
          { "type": "products-listing" }
        ]
      }
    ]
  }
{% endschema %}