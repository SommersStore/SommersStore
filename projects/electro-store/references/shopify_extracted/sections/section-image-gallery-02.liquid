{%- assign _hide_mobile = section.settings.hide_mobile -%}
{%- assign _layout = section.settings.layout -%}
{%- assign _item_per_row = section.settings.item_per_row -%}

<div class="home-banner-02 layout-{{_layout }}{% if _hide_mobile %} d-none d-md-block{% endif %}">
  {% if _layout == 'boxed' and settings.left_column_style == 'none' %}<div class="container">{% endif %}

  {% if section.blocks.size > 0 %}

    <div class="banner-grid banner-grid-{{ section.id }}">

        {% for block in section.blocks %}
      	{%- assign _image_size = block.settings.image_size -%}

        <div class="banner-item">
          {% unless block.settings.image == blank %}
            <a href="{{ block.settings.link }}"{% if _lazyload %} class="lazyload waiting"{% endif %}>
              <img {% if _lazyload %}class="lazyload" data-{% endif %}src="{{ block.settings.image | img_url: _image_size }}" alt="Banner" />
            </a>
          
          	{% unless block.settings.text == blank %}
              <a href="{{ block.settings.link }}" class="text">{{ block.settings.text }}</a>
          	{% endunless %}

          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}

          {% endunless %}
        </div>

      {% endfor %}

    </div>

  {% else %}
      <div class="banner-grid banner-grid-{{ section.id }}">
        {% for i in (1.._item_per_row) %}
          <div class="banner-item">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {% endfor %}
      </div>

  {% endif %}

  {% if _layout == 'boxed' and settings.left_column_style == 'none' %}</div>{% endif %}
</div>

  <script>
    jQuery(document).ready(function($) {

        setTimeout(function(){
          jQuery(".banner-grid-{{ section.id }}").length && jQuery('.banner-grid-{{ section.id }}').owlCarousel({
            nav			: true
            ,dots 		: false
            ,margin		: 20
            ,responsive : {
                0:{
                  items: 2
                }
                ,480:{
                  items: 3
                }
                ,768:{
                  items: 4
                }
                ,991:{
                  items: 5
                }
                ,1024:{
                  items: 6
                }
                ,1200:{
                    items: {{ _item_per_row }}
                } 
              }
            ,navText	: ['<span class="button-prev"></span>', '<span class="button-next"></span>']
          });
        }, 1200);

    });
  </script>

{% schema %}
{
  "name": "Image Gallery Style 02",
  "settings": [
	{
      "type": "paragraph",
      "content": "Created by 'Image Gallery Style 02' section"
    },
    {
      "id": "title",
      "type": "text",
      "label": "Section Label",
      "default": "Image Gallery 2"
    },
  	{
      "type": "checkbox",
      "id": "lazyload",
      "label": "Enable Lazy loading",
      "default": true
    },
    {
      "type": "header",
      "content": "Layout"
    },
	{
      "type": "checkbox",
      "id": "hide_mobile",
      "label": "Visibility: Hide for Mobile"
    },
	{
      "type": "select",
      "id": "layout",
      "label": "Section Layout Mode",
      "default": "boxed",
      "options": [
        {
          "value": "boxed",
          "label": "Boxed"
        },
        {
          "value": "full",
          "label": "Wide"
        }
      ]
    },
	{
      "type": "range",
      "id": "item_per_row",
      "label": "Number of items per row",
      "min": 6,
      "max": 10,
      "step": 1,
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
		{
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
		{
          "type": "text",
          "id": "image_size",
          "label": "Image size (pixels)",
          "default": "125x75",
          "info": "For exam: 125x75"
        },
		{
          "type": "text",
          "id": "text",
          "label": "Text"
        },
		{
          "type": "url",
          "id": "link",
          "label": "Link to"
        }
      ]
    }
    
  ],
  "presets": [
    {
      "name": "Image Gallery Style 02",
      "category": "Banner",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
		{ "type": "image" },
		{ "type": "image" },
		{ "type": "image" },
		{ "type": "image" },
		{ "type": "image" },
		{ "type": "image" },
		{ "type": "image" },
		{ "type": "image" }
      ]
    }
  ]
}
{% endschema %}
