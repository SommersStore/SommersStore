{% unless settings.breadcrumb_styles == 'none' %}{% include 'breadcrumb' %}{% endunless %}

{%- assign _layout = section.settings.layout -%}

{% if _layout == 'none-sidebar' %}
  {%- assign _main_class = "col-12" -%}
{% else %}
  {%- assign _sb_class = "col-md-3 d-none d-md-block" -%}
  {%- assign _main_class = "col-md-9 col-sm-12 col-12" -%}
{% endif %}

{%- assign new_comment = false -%}
{% if comment and comment.created_at %}
  {%- assign new_comment = true -%}
  {%- assign new_comment_id = comment.id -%}
{% endif %}

{% if new_comment %}
  {%- assign duplicate_comment = false %}
  {% for comment in article.comments %}
    {% if comment.id == new_comment_id %}
      {%- assign duplicate_comment = true %}
      {% break %}
    {% endif %}
  {% endfor %}

  {% if duplicate_comment %}
    {%- assign number_of_comments = article.comments_count -%}
  {% else %}
    {%- assign number_of_comments = article.comments_count | plus: 1 -%}
  {% endif %}
{% else %}
  {%- assign number_of_comments = article.comments_count -%}
{% endif %}

<div class="page-article layout-{{ _layout }}">
  <div class="container">
    <div class="row">
  
      {% if _layout == 'left-sidebar' %}
        {% include 'sidebar-blog' %}
      {% endif %}

      <div class="{{ _main_class }}">

        <article class="post">
          {% if article.image %}
            <div class="post-image">
              <img src="{{ article | img_url: '1170x' }}" alt="Article" />
            </div>
          {% endif %}

          <div class="post-content">

            <h3 class="post-title">{{ article.title }}</h3>

            <div class="post-info">
              <ul class="list-inline">
                <li><a href="/blogs/{{ blog.title | handleize }}" class="post-t">{{ blog.title }}</a></li>
                <li><span class="post-date">{{ article.created_at | date: "%d %b, %Y" }}</span></li>
                <li><span class="post-author">{{ 'blogs.article.posted_by' | t }} {{ article.author | escape }}</span></li>
              </ul>
            </div>

            <div class="post-des">{{ article.content }}</div>     
          </div>
          
          {% if section.settings.show_share_buttons %}
            {% include 'social-sharing' %}
          {% endif %}

          {% unless section.settings.author_image == blank %}
            <div class="post-author-info">
              <div class="media">
                <div class="image"><img src="{{ section.settings.author_image | img_url: "180x" }}" alt="Admin" /></div>
                <div class="text"><span class="author">{{ article.author }}</span></div>
              </div>
            </div>
          {% endunless %}

        </article>
            
        {% if blog.comments_enabled? %}
          {% if number_of_comments > 0 %}
            <div class="grid-comments">
              <h5>{{ 'blogs.comments.comments_with_count' | t: count: number_of_comments }}</h5>

              {% paginate article.comments by 5 %}

              {% comment %}
                #comments is required, it is used as an anchor link by Shopify.
              {% endcomment %}
              
                <div id="comments">

                    {% if new_comment %}
                      <p class="note form-success">
                        {% if blog.moderated? %}
                          {{ 'blogs.comments.success_moderated' | t }}
                        {% else %}
                          {{ 'blogs.comments.success' | t }}
                        {% endif %}
                      </p>
                    {% endif %}

                    <ul class="comments">
                      {% comment %}
                        If a comment was just submitted with no blank field, show it.
                      {% endcomment %}
                      {% if new_comment %}
                        <li id="{{ comment.id }}" class="comment">
                          {% include 'comment' %}
                        </li>
                      {% endif %}

                      {% for comment in article.comments %}
                        {% unless comment.id == new_comment_id %}
                          <li id="{{ comment.id }}" class="comment">
                            {% include 'comment' %}
                          </li>
                        {% endunless %}
                      {% endfor %}
                    </ul>

                    {% if paginate.pages > 1 %}
                      {% include 'pagination' %}
                    {% endif %}

                </div>
                  
              {% endpaginate %}
            </div>
          {% endif %}
            
          <div class="comment-form">
            {% form 'new_comment', article %}

              <h3>{{ 'blogs.comments.title' | t }}</h3>

              {{ form.errors | default_errors }}

              {% if blog.moderated? %}
                <p class="moderated">{{ 'blogs.comments.moderated' | t }}</p>
              {% endif %}

              <div class="grid-form">
                <div class="row">
                  <div class="control-wrapper col-md-6 col-sm-12">
                    <input type="text" name="comment[author]" id="comment-author" class="{% if form.errors contains 'author' %} input-error{% endif %}" placeholder="{{'blogs.comments.name' | t }}" value="{{ form.author }}">
                  </div>

                  <div class="control-wrapper col-md-6 col-sm-12">
                    <input type="email" name="comment[email]" id="comment-email" class="{% if form.errors contains 'email' %} input-error{% endif %}" placeholder="{{'blogs.comments.email' | t }}" value="{{ form.email }}" autocorrect="off" autocapitalize="off">
                  </div>
                </div>

                <div class="control-wrapper">
                  <textarea name="comment[body]" id="comment-body" class="{% if form.errors contains 'body' %} input-error{% endif %}" placeholder="{{'blogs.comments.message' | t }}">{{ form.body }}</textarea>
                </div>
              </div>

              <input type="submit" class="btn btn-1" value="{{ 'blogs.comments.submit' | t }}">
            {% endform %}
          </div>
            
        {% endif %}
        
      </div>

      {% if _layout == 'right-sidebar' %}
        {% include 'sidebar-blog' %}
      {% endif %}
    
    </div>
  </div>
</div>


{% schema %}
  {
    "name": "Article pages",
    "settings": [
      {
        "type": "image_picker",
        "id": "breadcrumb_image",
        "label": "Breadcrumb image"
      },
      {
        "type": "select",
        "id": "layout",
        "label": "Section Layout Mode",
        "options": [
          {
            "value": "left sidebar",
            "label": "Left-sidebar"
          },
          {
            "value": "right-sidebar",
            "label": "Right sidebar"
          },
          {
            "value": "none-sidebar",
            "label": "None sidebar"
          }
        ],
        "default": "right-sidebar"
      },
      {
        "type": "checkbox",
        "id": "show_share_buttons",
        "label": "Show social sharing buttons",
        "default": true
      },
      {
        "type": "image_picker",
        "id": "author_image",
        "label": "Author image"
      },
      {
        "type": "header",
        "content": "Sidebar Search"
      },
      {
        "type": "checkbox",
        "id": "enable_search_blog",
        "label": "Enable Search Form",
        "default": true
      },
      {
        "type": "header",
        "content": "Sidebar About"
      },
      {
        "type": "checkbox",
        "id": "enable_about_blog",
        "label": "Enable Sidebar About",
        "default": true
      },
      {
        "type": "text",
        "id": "about_blog_title",
        "label": "Heading"
      },
      {
        "type": "textarea",
        "id": "about_blog_caption",
        "label": "Caption"
      },
      {
        "type": "header",
        "content": "Sidebar Categories"
      },
      {
        "type": "text",
        "id": "blog_categories_title",
        "label": "Heading",
		"default": "Categories"
      },
      {
        "type": "link_list",
        "id": "blog_categories_menu",
        "label": "Menu item",
        "info": "Blank to hide"
      },
      {
        "type": "header",
        "content": "Sidebar Posts"
      },
      {
        "type": "text",
        "id": "sidebar_post_title",
        "label": "Heading",
		"default": "Recent posts"
      },
      {
        "type": "blog",
        "id": "sidebar_post",
        "label": "Blog item",
		"info": "Blank to hide"
      },
      {
        "type": "text",
        "id": "sidebar_post_limit",
        "label": "Total items",
        "default": "3"
      },
      {
        "type": "header",
        "content": "Sidebar Tags"
      },
      {
        "type": "checkbox",
        "id": "enable_sidebar_tags",
        "label": "Enable Sidebar Tags",
        "default": true
      },
      {
        "type": "text",
        "id": "sidebar_tags_title",
        "label": "Heading",
		"default": "Tags"
      }
    ]
  }
{% endschema %}