{%- assign _show_slideshow = section.settings.show_slideshow -%}
{%- assign _hide_mobile = section.settings.hide_mobile -%}
{%- assign _full_height = section.settings.full_height -%}
{%- assign _lazyload = section.settings.lazyload -%}

{% unless settings.left_column_style == 'none' %}
  {%- assign _have_left_column = true -%}
  {%- assign _layout = 'full' -%}
{% else %}
  {%- assign _have_left_column = false -%}
  {%- assign _layout = section.settings.layout -%}
{% endunless %}

{% capture emptyImage %}
  <div class="image">
    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
  </div>
{% endcapture %}

{% if _show_slideshow %}
<div class="slideshow-01 slideshow-catalog-wrapper{% if section.settings.enable_three_banner %} sidebar-banner{% endif %}">
  <div class="bc-wrapper{% if _full_height %} full-height{% endif %} {{ _layout }}{% if _hide_mobile %} d-none d-md-block{% endif %}" style="background-color: {{ section.settings.background }};">
      
    <div class="bc-home-slideshow">
      {% if section.blocks.size > 0 %}
        <div class="home-slideshow-wrapper swiper-container swiper-container-01" data-autoplay="{{ section.settings.autoplay }}" data-time="{{ section.settings.autoplay_speed }}" data-animation="{{ section.settings.animation }}">
          <div class="home-slideshow swiper-wrapper">

            {% for block in section.blocks %}
              {% if block.type == 'image' %}
                {%- assign image = block.settings.image -%}
                {%- assign video = block.settings.video -%}
                {%- assign link = block.settings.link -%}
                {%- assign textAlign = block.settings.alignment -%}
                {%- assign position = block.settings.position -%}
                {%- assign headingText = block.settings.heading -%}
            	{%- assign headingBoldText = block.settings.heading_bold -%}
                {%- assign headingAnimation = block.settings.heading_animation -%}
                {%- assign headingAnimationDelay = block.settings.heading_animation_delay -%}
                {%- assign headingColor = block.settings.heading_color -%}
                {%- assign headingSize = block.settings.heading_size -%}
                {%- assign subheadingText = block.settings.subheading -%}
            	{%- assign subheadingBoldText = block.settings.subheading_bold -%}
                {%- assign subheadingAnimation = block.settings.subheading_animation -%}
                {%- assign subheadingAnimationDelay = block.settings.subheading_animation_delay -%}
                {%- assign subheadingColor = block.settings.subheading_color -%}
                {%- assign subheadingSize = block.settings.subheading_size -%}
                {%- assign captionText = block.settings.caption -%}
            	{%- assign captionBoldText = block.settings.caption_bold -%}
                {%- assign captionAnimation = block.settings.caption_animation -%}
                {%- assign captionAnimationDelay = block.settings.caption_animation_delay -%}
                {%- assign captionColor = block.settings.caption_color -%}
                {%- assign captionSize = block.settings.caption_size -%}
                {%- assign buttonText = block.settings.button_text -%}              
                {%- assign buttonAnimation = block.settings.button_animation -%}
                {%- assign buttonAnimationDelay = block.settings.button_animation_delay -%}

                {% unless image == blank  %}
                  <div class="swiper-slide{% unless video == blank %} has-video{% endunless %} swiper-slide-{{ block.id }}{% if _lazyload %} lazyload{% endif %}" style="background-image:url({{ block.settings.image | img_url: '1920x' }}); width: 100%;">
                    <a href="{{ link }}"><img src = "{{ block.settings.image | img_url: '1920x' }}" alt="" /></a>

                      <div class="swiper-content {{ textAlign }} slide-{{ forloop.index }}{% if _have_left_column == false %} container{% endif %}{% if section.settings.fix_text_box_position %} fix-textbox{% endif %}" style="top: {{ position }};">
                        <div class="container-box">

                              {% unless headingText == blank %}<div class="heading bold-{{ headingBoldText }}">{{ headingText }}</div>{% endunless %}

                              {% unless subheadingText == blank %}<div class="subheading bold-{{ subheadingBoldText }}">{{ subheadingText }}</div>{% endunless %}

                              {% unless captionText == blank %}<div class="cation bold-{{ captionBoldText }}">{{ captionText }}</div>{% endunless %}

                              {% unless buttonText == blank %}
                                <div class="caption-link">
                                  <a class="slider-button btn btn-1" href="{{ link }}">{{ buttonText }}</a>                
                                </div>
                              {% endunless %}

                              <style type="text/css">
                                .swiper-slide-{{ block.id }}.swiper-slide-active .heading{
                                  color: {{ headingColor }}; font-size: {{ headingSize }}; -webkit-animation-name: {{headingAnimation }}; animation-name: {{ headingAnimation }}; -webkit-animation-delay: {{ headingAnimationDelay }}; animation-delay: {{ headingAnimationDelay }};
                                }
                                .swiper-slide-{{ block.id }}.swiper-slide-active .subheading{
                                  color: {{ subheadingColor }}; font-size: {{ subheadingSize }}; -webkit-animation-name: {{ subheadingAnimation }}; animation-name: {{ subheadingAnimation }}; -webkit-animation-delay: {{ subheadingAnimationDelay }}; animation-delay: {{ subheadingAnimationDelay }};
                                }
                                .swiper-slide-{{ block.id }}.swiper-slide-active .cation{
                                  color: {{ captionColor }}; font-size: {{ captionSize }}; -webkit-animation-name: {{ captionAnimation }}; animation-name: {{ captionAnimation }}; -webkit-animation-delay: {{ captionAnimationDelay }}; animation-delay: {{ captionAnimationDelay }};
                                }
                                .swiper-slide-{{ block.id }}.swiper-slide-active .caption-link{
                                  -webkit-animation-name: {{ buttonAnimation }}; animation-name: {{ buttonAnimation }}; -webkit-animation-delay: {{ buttonAnimationDelay }}; animation-delay: {{ buttonAnimationDelay }};
                                }                                                                                                             
                              </style>

                          </div> 

                        </div>

                        {% unless video == blank %}
                          <div class="video-slide" style="display: none;">
                            <video controls class="video lazyload" autoplay="" loop="" muted="" preload="auto" data-width="0" data-height="0">
                              <source src="{{ video }}" type="video/mp4">
                            </video>
                          </div>
                        {% endunless %}

                  </div>

                {% else %}

                  <div class="swiper-slide">
                    <a href="{{ link }}">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</a>
                  </div>

                {% endunless %}

              {% endif %}
            {% endfor %}

          </div>

          {% for block in section.blocks %}
            {% if block.type == 'product' %}
              <div class="tab-wrapper">
                <div class="nav-tab-wrapper">
                  <ul class="nav nav-tabs tab-heading" role="tablist">

                    {%- assign j = 0 -%}
                    {% for i in (1..6) %}
                      {%- assign _collection = 'collection_' | append: i -%}
                      {%- assign _coll = collections[block.settings[_collection]] -%} 

                      {% unless _coll == blank %}
                        {%- assign j = j | plus: 1 -%}
                        <li class="nav-item">
                          <a class="nav-link{% if j == 1 %} active{% endif %}{% if _lazyload %} lazyload{% endif %}" href="#slideshow-tabs-{{ section.id }}-{{ forloop.index }}" aria-controls="slideshow-tabs-{{ section.id }}-{{ forloop.index }}" role="tab" data-toggle="tab">
                            {{ _coll.title }}
                          </a>
                        </li>
                      {% endunless %}

                    {% endfor %}

                  </ul>
                </div>

                <div class="tab-content">
                  {%- assign k = 0 -%}

                  {% for i in (1..6) %}
                    {%- assign _collection = 'collection_' | append: i -%}
                    {%- assign _coll = collections[block.settings[_collection]] -%} 

                    {% unless _coll == blank %}
                      {%- assign k = k | plus: 1 -%}
                      <div role="tabpanel" class="{% if k == 1 %}show active {% endif %}tab-pane" id="slideshow-tabs-{{ section.id }}-{{ forloop.index }}">
                        <div class="slideshow-tabs-list">

                          {% for product in _coll.products limit: 10 %}
                          {% include 'product-item' %}
                          {% endfor %}

                        </div>
                      </div>
                    {% endunless %}

                  {% endfor %}
                </div>

              </div>
            {% endif %}
          {% endfor %}
        </div>

        <div class="btn-pagination">
          {% if section.settings.paging %}
            <div class="swiper-pagination swiper-pagination-01 swiper-pagination-white"></div>
          {% endif %}

          {% if section.settings.navigator %}
            <div class="swiper-button-next swiper-button-next-01 swiper-button-white"></div>
            <div class="swiper-button-prev swiper-button-prev-01 swiper-button-white"></div>
          {% endif %}
        </div>

        <script>
          jQuery(document).ready(function($) {
            if ( bcMsieVersion.MsieVersion() == 0 ){ AT_Main.homeSlideshow(); }
            else{ AT_Main.homeIE();}
          });
        </script>

      {% else %}

      <div class="home-slideshow-wrapper swiper-container">
        <div class="home-slideshow swiper-wrapper">

          <div class="swiper-slide">
            <a href="{{ link }}">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</a>
          </div>

        </div>
      </div>

      {% endif %}
    </div>

    {% if section.settings.enable_three_banner %}
      <div class="bc-three-banner">

        {% unless section.settings.three_image_1 == blank %}
          <a href="{{ section.settings.three_link_1 }}">
            <img src="{{ section.settings.three_image_1 | img_url: '370x' }}'" alt="Banner" />
          </a>
        {% endunless %}

        {% unless section.settings.three_image_2 == blank %}
          <a href="{{ section.settings.three_link_2 }}">
            <img src="{{ section.settings.three_image_2 | img_url: '370x' }}'" alt="Banner" />
          </a>
        {% endunless %}

        {% unless section.settings.three_image_3 == blank %}
          <a href="{{ section.settings.three_link_3 }}">
            <img src="{{ section.settings.three_image_3 | img_url: '370x' }}'" alt="Banner" />
          </a>
        {% endunless %}

      </div>
    {% endif %}
    
  </div>
</div>
{% endif %}

{% schema %}
