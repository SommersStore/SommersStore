{
  "hosting": {
    "public": "projects/loja-digital/out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/sais",
        "destination": "/sales/v3/zen-dark-v3.html"
      },
      {
        "source": "/vsl",
        "destination": "/sales/vsl.html"
      },
      {
        "source": "/vls",
        "destination": "/sales/vsl.html"
      },
      {
        "source": "/oto",
        "destination": "/sales/oto.html"
      }
    ]
  }
}
