{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": ["node_modules", ".git", "firebase-debug.log", ".env"]
    }
  ],
  "hosting": {
    "public": "projects/loja-digital/out_deploy",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "redirects": [
      {
        "source": "/vsl",
        "destination": "/sais",
        "type": 301
      },
      {
        "source": "/oto",
        "destination": "/sais/upsell-1",
        "type": 301
      },
      {
        "source": "/vls",
        "destination": "/sais",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/sais.html"
      },
      {
        "source": "/sais",
        "destination": "/sais.html"
      },
      {
        "source": "/sais/upsell-1",
        "destination": "/sais/upsell-1.html"
      },
      {
        "source": "/login",
        "destination": "/login.html"
      },
      {
        "source": "/hub",
        "destination": "/hub.html"
      },
      {
        "source": "/ebook/viewer",
        "destination": "/ebook/viewer.html"
      },
      {
        "source": "/ebook/cofre-v2",
        "destination": "/ebook/cofre-v2.html"
      }
    ]
  }
}
