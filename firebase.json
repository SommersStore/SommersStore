{
  "hosting": {
    "public": "projects/loja-digital/out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/v3/zen-dark-v3",
        "destination": "/sales/v3/zen-dark-v3.html"
      },
      {
        "source": "/v3/zen-magic",
        "destination": "/sales/v3/zen-magic.html"
      },
      {
        "source": "/v3/zen-cosmic",
        "destination": "/sales/v3/zen-cosmic.html"
      }
    ]
  }
}
