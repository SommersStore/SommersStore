rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function mobileControlPath() {
      return /databases/$(database)/documents/financasMobileControl/main;
    }

    function mobileEnabled() {
      return !exists(mobileControlPath()) || get(mobileControlPath()).data.enabled == true;
    }

    match /financasMobileControl/main {
      allow read: if true;
      allow write: if false;
    }

    match /users/{userId}/financasMobileInbox/{entryId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && mobileEnabled()
        && request.resource.data.status == 'pending'
        && request.resource.data.source == 'financas-mobile-cloud';
      allow update: if request.auth != null
        && request.auth.uid == userId
        && resource.data.source == 'financas-mobile-cloud'
        && request.resource.data.status in ['pending', 'imported'];
      allow delete: if false;
    }
  }
}
