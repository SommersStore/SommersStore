# Dependências
node_modules/
.pnp
.pnp.js

# Build outputs
.next/
out/
dist/
build/

# Variáveis de ambiente (NUNCA commitar)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Arquivos de teste temporários na raiz
/test-*.js
/test-*.ts
/test-*.py
/vt.js
/tmp/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Cache e runtime AIOX
.aiox/
.cache/
*.cache

# Backups locais de dados financeiros sensiveis
projects/financas/data/recovery/

# Dados pessoais, anexos e estado local do painel
.claude/settings.local.json
*.lnk
docs/uploads/
projects/financas/contracts/
projects/financas/data/
projects/imposto-de-renda/data/
docs/control/sessions/
docs/control/archive/

# Caches reconstruiveis de pesquisa
projects/forex/research/rimantas-channel/player-cache/
projects/forex/research/rimantas-channel/transcript-analysis-cache/

# Sistemas operacionais
.DS_Store
._*
Thumbs.db
desktop.ini

# Firebase
.firebase/
firebase-debug.log
firestore-debug.log

# Certificados e chaves
*.pem
*.key
*.cert
