# =============================================
# SommersStore — .gitignore raiz
# =============================================

# Dependências
node_modules/
.pnp
.pnp.js

# Build outputs
.next/
out/
dist/
build/

# Variáveis de ambiente (NUNCA commitar)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Arquivos de teste temporários na raiz
/test-*.js
/test-*.ts
/test-*.py
/vt.js
/tmp/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Cache e runtime AIOX
.aiox/
.cache/
*.cache

# Sistemas operacionais
.DS_Store
._*
Thumbs.db
desktop.ini

# Firebase
.firebase/
firebase-debug.log
firestore-debug.log

# Certificados e chaves
*.pem
*.key
*.cert
